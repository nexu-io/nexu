  <script>
    // Nexu heading animation observer
    const nexuEl = document.getElementById('nexu-heading');
    if (nexuEl) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            nexuEl.classList.remove('animate');
            void nexuEl.offsetWidth;
            nexuEl.classList.add('animate');
            nexuEl.addEventListener('animationend', () => {
              nexuEl.classList.remove('animate');
            }, { once: true });
          }
        });
      }, { threshold: 0.5 });
      observer.observe(nexuEl);
    }
  </script>
  <script>
    // Text reveal → toc-module sequencing
    const textRevealEl = document.getElementById('nexu-text-reveal');
    const tocModule = document.getElementById('toc-module');
    if (textRevealEl && tocModule) {
      let triggered = false;

      function showToc() {
        if (triggered) return;
        triggered = true;
        tocModule.style.opacity = '1';
        tocModule.style.transform = 'translateY(0)';
      }

      const fullyVisible = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting && !triggered) {
            const words = textRevealEl.innerText.trim().split(/\s+/).length;
            const delay = words * 55 + 800;
            setTimeout(showToc, delay);
            fullyVisible.unobserve(textRevealEl);
          }
        });
      }, { threshold: 1.0 });

      fullyVisible.observe(textRevealEl);

      // Fallback
      const fallback = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting && !triggered) {
            setTimeout(showToc, 500);
          }
        });
      }, { threshold: 0 });
      fallback.observe(textRevealEl);
    }
  </script>
  <script>
    // Footer logo hover effects
    const footerLogo = document.getElementById('footer-logo');
    if (footerLogo) {
      footerLogo.querySelectorAll('path[data-hover-fill]').forEach(path => {
        const hoverColor = path.getAttribute('data-hover-fill');
        path.addEventListener('mouseenter', () => { path.style.fill = hoverColor; });
        path.addEventListener('mouseleave', () => { path.style.fill = '#2D2D2D'; });
      });
    }
  </script>
  <script>
    // Footer aurora observer
    const footerAurora = document.getElementById('footer-aurora');
    if (footerAurora) {
      new IntersectionObserver((entries) => {
        entries.forEach(e => { if (e.isIntersecting) footerAurora.classList.add('is-visible'); });
      }, { threshold: 0.05 }).observe(footerAurora);
    }
  </script>
