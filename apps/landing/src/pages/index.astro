---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import StrikethroughList from "../components/StrikethroughList.tsx";
import TextReveal from "../components/TextReveal.tsx";
import KpiCards from "../components/KpiCards.tsx";
import FeaturesScrollTunnel from "../components/FeaturesScrollTunnel.tsx";
import VideoModal from "../components/VideoModal.tsx";
import ToolsScrollTunnel from "../components/ToolsScrollTunnel.tsx";
---

<html lang="en-US" class="scroll-smooth">

<head>
  <meta charset="UTF-8">
  <style>
    .nexu-text {
      font-size: 1.3em;
      font-weight: bold;
      color: white;
    }
    .nexu-text.animate {
      background: linear-gradient(90deg,
        #ffffff 0%,
        #ffffff 20%,
        #ff0000 30%,
        #ff9900 38%,
        #ffff00 46%,
        #00ff00 54%,
        #00aaff 62%,
        #aa00ff 70%,
        #ffffff 80%,
        #ffffff 100%
      );
      background-size: 300% 100%;
      background-position: 200% center;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: nexu-sweep 1.8s ease-in-out forwards;
    }
    @keyframes nexu-sweep {
      0%   { background-position: 200% center; }
      100% { background-position: -50% center; }
    }
    [data-bg="black"] [data-background] {
      transform: none !important;
      transform-origin: center !important;
    }
  </style>
  <style>
    @keyframes footer-blob-drift {
      0%, 100% { transform: translate(0, 0) scale(1); }
      33%       { transform: translate(-3%, -6%) scale(1.06); }
      66%       { transform: translate(4%, 3%) scale(0.96); }
    }
    .footer-aurora {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 420px;
      pointer-events: none;
      overflow: hidden;
      opacity: 0;
      transition: opacity 2.4s ease;
      z-index: 0;
    }
    .footer-aurora.is-visible { opacity: 1; }
    .footer-aurora-inner {
      position: absolute;
      inset: 0;
      filter: blur(72px);
    }
    .footer-aurora-blob {
      position: absolute;
      border-radius: 50%;
    }
    .footer-aurora-blob-1 {
      width: 70%; height: 360px;
      background: radial-gradient(circle, rgba(106,125,241,.92) 0%, transparent 65%);
      top: -100px; left: 15%;
      animation: footer-blob-drift 9s ease-in-out infinite;
    }
    .footer-aurora-blob-2 {
      width: 85%; height: 300px;
      background: radial-gradient(circle, rgba(248,103,47,.88) 0%, transparent 65%);
      top: 30px; left: 5%;
      animation: footer-blob-drift 12s ease-in-out infinite reverse;
    }
    .footer-aurora-blob-3 {
      width: 45%; height: 260px;
      background: radial-gradient(circle, rgba(217,153,247,.85) 0%, transparent 65%);
      top: 100px; left: 28%;
      animation: footer-blob-drift 7s ease-in-out infinite 2s;
    }
    .footer-aurora-blob-4 {
      width: 90%; height: 300px;
      background: radial-gradient(circle, rgba(6,238,255,.82) 0%, transparent 65%);
      bottom: -60px; left: 5%;
      animation: footer-blob-drift 14s ease-in-out infinite 1s;
    }
    .footer-aurora-blob-5 {
      width: 40%; height: 220px;
      background: radial-gradient(circle, rgba(255,208,50,.80) 0%, transparent 65%);
      top: -40px; right: 8%;
      animation: footer-blob-drift 10s ease-in-out infinite 3s reverse;
    }
  </style>
  <style>
    @keyframes kpi-breathe {
      0%, 100% { scale: 1; }
      50% { scale: 1.045; }
    }
    .kpi-card {
      animation: kpi-breathe 4s ease-in-out infinite;
    }
  </style>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nexu &ndash; Your Digital Employee</title>
  <meta content="Nexu packages OpenClaw into the simplest multi-agent platform for teams. Deploy in 1 min. Zero data loss. 3,000+ tools, one-click connect." name="description">
  <meta content="Nexu &ndash; Your Digital Employee" property="og:title">
  <meta content="Nexu packages OpenClaw into the simplest multi-agent platform for teams. Deploy in 1 min. Zero data loss." property="og:description">
  <meta content="Nexu" property="og:site_name">
  <meta content="website" property="og:type">
  <meta content="all" name="robots">

